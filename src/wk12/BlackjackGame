class BlackjackGame {
    static Random rand = new Random();
    static Scanner input = new Scanner(System.in);
    public static void main(String[] args) {
        
        String[] suits = {"Hearts", "Spades", "Clubs", "Diamonds"};
        
        String[] ranks = {"Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine", "Ten", "Jack", "Queen", "King", "Ace"};
        
        Card[] deck = new Card[52];
        int deckIndex = -1;
        
        for(String suit : suits){
            
            for(int i = 0; i < ranks.length; i++){
            deckIndex++;
                int value = i  < 8 ? i + 2 : 10;
                if(i == 12){
                    value = 11;
                }
                deck[deckIndex] = new Card(suit, ranks[i], value );
            }
            
        }
        
        BlackJackPlayer p1 = new BlackJackPlayer("John");
        Dealer d1 = new Dealer("Dealer");
        
        play(p1, deck);
        play(d1, deck);
        
        Participant winner, loser;
        
        winner = p1.getHandTotal() == Participant.BLACKJACK || p1.getHandTotal() < Participant.BLACKJACK && p1.getHandTotal() > d1.getHandTotal() ? p1 : d1 ;
        
        loser = winner.getName().equals(p1.getName()) ? d1 : p1;
        
        summary(winner, "Won");
        System.out.println("*".repeat(10));
        summary(loser, "Loss");
        
        
        
    }
    static void summary(Participant p, String status){
                System.out.println(p.getName() + " " + status + "!");
        System.out.println(p.getName() + " had a score of " + p.getHandTotal() );
        p.getHand();

    }
    static Card getCardFromDeck(Card[] deck){
        int ranIndex;
        do{
        ranIndex = rand.nextInt(deck.length);
        
        }
        while(deck[ranIndex].isUsed());
        
        deck[ranIndex].setAsUsed();
        
        return deck[ranIndex];
    }
    static void play(Participant p, Card[] deck){
        p.addCardToHand(getCardFromDeck(deck));
        p.addCardToHand(getCardFromDeck(deck));
        String answer;
        
        
        
        while(
            p instanceof BlackJackPlayer && ((BlackJackPlayer)p).canPlay()  || 
            p instanceof Dealer && ((Dealer)p).canPlay()  
        
        ){
            p.getHand();
            System.out.println("Would you like to (h)it or (s)tay?");
            answer = input.nextLine();
            if(answer.length() > 0 && answer.toLowerCase().trim().charAt(0) == 'h'){
                p.addCardToHand(getCardFromDeck(deck));
                if(p.getHandTotal() == Participant.BLACKJACK){
                    System.out.println(p.getName() + " got Blackjack");
                }
                else if(p.getHandTotal() > Participant.BLACKJACK){
                    System.out.println(p.getName() + " Busted!");
                }
                continue;    
            }
            break;
            
        }        
    }
}
